DATABASE_URL="file:./dev.db"

GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
ALLOW_LOCAL_MOCK_SESSION="true"

# Production notes:
# NEXTAUTH_URL should be your live domain, for example https://easyframe.app
# ALLOW_LOCAL_MOCK_SESSION should be false or omitted in production.

DODO_API_KEY="dodo_sandbox_api_key"
DODO_WEBHOOK_SECRET="dodo_sandbox_webhook_secret"
DODO_MONTHLY_PRODUCT_ID="prod_monthly_sandbox"
DODO_YEARLY_PRODUCT_ID="prod_yearly_sandbox"
DODO_LIFETIME_PRODUCT_ID="prod_lifetime_sandbox"
DODO_MONTHLY_CHECKOUT_URL="https://checkout.dodopayments.com/buy/monthly_sandbox"
DODO_YEARLY_CHECKOUT_URL="https://checkout.dodopayments.com/buy/yearly_sandbox"
